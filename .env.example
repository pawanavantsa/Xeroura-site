# Resend (https://resend.com) — domain must be verified; MAIL_FROM must be allowed for that domain.
RESEND_API_KEY=re_xxxxxxxxxxxx
MAIL_TO=connect@xeroura.com
# Optional: comma-separated list
# MAIL_TO=connect@xeroura.com,hiring@xeroura.com

# Use a verified sender. Examples:
# MAIL_FROM=connect@xeroura.com
# MAIL_FROM="Xeroura Website <onboarding@xeroura.com>"

MAIL_FROM=connect@xeroura.com

# Optional — for correct Open Graph URLs in production
# NEXT_PUBLIC_SITE_URL=https://xeroura.com
